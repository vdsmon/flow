.DS_Store
*.swp
.idea/
.vscode/

# Claude Code local/transient state
.claude/settings.local.json
.claude/settings.json
.claude/scheduled_tasks.*
.claude/shell-snapshots/
.claude/todos/
.claude/history/
.claude/statsig/
.claude/projects/
.claude/worktrees/

# Python caches + venv anywhere under the flow plugin (ruff, pytest, bytecode, venv)
plugins/flow/**/.pytest_cache/
plugins/flow/**/.ruff_cache/
plugins/flow/**/__pycache__/
plugins/flow/**/.venv/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# flow transient run state (workspace.toml + .initialized stay tracked)
# unanchored **/ so a phantom nested <subdir>/.flow/... (drifted-cwd leak) is ignored too
**/.flow/runs/
**/.flow/worktrees/
**/.flow/*.lock
# bootstrap claim flock targets (tickets/<key>.md stays tracked; *.lock above
# does not reach the subdir)
**/.flow/tickets/*.claim
**/.flow/memory-root
**/.flow/recall-pending.jsonl
**/.flow/recall-pending.jsonl.lock
**/.flow/launch-ledger/
**/.flow/fleet/
# per-namespace memory + friction + ship-events (local, per-machine)
**/.flow/*/knowledge.jsonl
**/.flow/*/knowledge.jsonl.lock
**/.flow/*/friction.jsonl
**/.flow/*/friction.jsonl.lock
**/.flow/*/ship-events/
