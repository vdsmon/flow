.DS_Store
*.swp
.idea/
.vscode/

# Local agent-generated review and planning artifacts
.lavish/
.superpowers/

# Claude Code local/transient state
.claude/settings.local.json
.claude/settings.json
.claude/scheduled_tasks.*
.claude/shell-snapshots/
.claude/todos/
.claude/history/
.claude/statsig/
.claude/projects/
.claude/worktrees/

# Python caches + venv anywhere under the flow plugin (ruff, pytest, bytecode, venv)
plugins/flow/**/.pytest_cache/
plugins/flow/**/.ruff_cache/
plugins/flow/**/__pycache__/
plugins/flow/**/.venv/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# flow transient run state (workspace.toml + .initialized stay tracked)
# unanchored **/ so a phantom nested <subdir>/.flow/... (drifted-cwd leak) is ignored too
**/.flow/runs/
**/.flow/worktrees/
**/.flow/*.lock
# flock targets under tickets/ (tickets/<key>.md stays tracked; *.lock above
# does not reach the subdir). The .lock line also keeps frontmatter .md.lock
# churn out of git_receipt's guarded status, which quarantines in-flight
# read-only capsules otherwise (flow-5ymw).
**/.flow/tickets/*.claim
**/.flow/tickets/*.lock
**/.flow/runtime/
**/.flow/memory/
# pre-v2 migration inputs remain ignored until the journaled move verifies them
**/.flow/memory-root
**/.flow/flow
**/.flow/skill_dir
# live queue + .lock flock + .stale eviction sidecar + .tmp atomic-write residue
**/.flow/recall-pending.jsonl*
**/.flow/launch-ledger/
**/.flow/fleet/
# pre-v2 per-namespace memory inputs (local, per-machine)
**/.flow/*/knowledge.jsonl
**/.flow/*/knowledge.jsonl.lock
**/.flow/*/knowledge.embed
**/.flow/*/knowledge.embed.lock
**/.flow/*/friction.jsonl
**/.flow/*/friction.jsonl.lock
**/.flow/*/recall-usage.jsonl
**/.flow/*/recall-usage.jsonl.lock
**/.flow/*/ship-events/
