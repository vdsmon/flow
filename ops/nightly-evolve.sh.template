#!/bin/bash
# Flow nightly maintenance: discover bounded fixes, check the loop's senses, and
# drain confirmed evolution work. Copy to ~/.flow-evolve/nightly-evolve.sh and
# replace {{REPO}}. Test-fire it before arming the launchd timer.
#
# FLOW_HOST selects the owner-session adapter:
#   claude -> claude -p "/flow ..."
#   codex  -> codex exec "$flow:flow ..."
#
# Each adapter call is one synchronous owner session. The owner may itself be
# backgrounded by its host or this wrapper, but Flow never launches detached host
# CLIs. Native collaboration agents own fan-out and waiting; Flow's worker-pool
# reducers enforce their capacity, read-only, and recovery decisions.

set -uo pipefail
export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH:-}"

REPO="{{REPO}}"
FLOW_HOST="${FLOW_HOST:-claude}"
FLOW_REFRESH_CMD="${FLOW_REFRESH_CMD:-}"
LOG="$HOME/.flow-evolve/logs/$(date +%Y%m%d-%H%M%S).log"
RECORD="$HOME/.flow-evolve/run-record.jsonl"

record() {
  printf '{"schedule":"nightly","phase":"%s","ts":"%s","outcome":"%s"}\n' \
    "$1" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "${2:-}" >>"$RECORD"
}

run_flow_owner() {
  local command="$1"
  case "$FLOW_HOST" in
    claude)
      claude -p "/flow $command"
      ;;
    codex)
      codex exec "\$flow:flow $command"
      ;;
    *)
      echo "unsupported FLOW_HOST=$FLOW_HOST (expected claude or codex)" >&2
      return 2
      ;;
  esac
}

{
  echo "=== Flow nightly maintenance: $(date) (host=$FLOW_HOST) ==="
  _RUN_OUTCOME=fail
  trap 'record end "$_RUN_OUTCOME"' EXIT
  record start
  cd "$REPO" || { echo "repo not found: $REPO"; exit 1; }

  SCRIPTS="$REPO/plugins/flow/skills/flow/scripts"
  branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '?')"
  echo "--- clean-boundary preflight before checkout/plugin mutation ---"
  if python3 "$SCRIPTS/maintainer_preflight.py" \
    --run-record "$RECORD" --workspace-root "$REPO" \
    --require-clean-boundary --json; then
    if [ "$branch" = "main" ]; then
      git fetch origin --quiet || true
      if git merge --ff-only origin/main; then
        if [ -n "$FLOW_REFRESH_CMD" ]; then
          echo "--- refreshing configured host installation ---"
          /bin/bash -lc "$FLOW_REFRESH_CMD" || true
        fi
      else
        echo "(ff-only skipped: checkout diverged; maintaining as-is)"
      fi
    else
      echo "(repo on '$branch', not main; maintaining current checkout)"
    fi
  else
    echo "(checkout/plugin refresh skipped: dirty checkout or live/corrupt run lease)"
  fi

  echo "--- owner: FLOW maintain evolution audit ---"
  run_flow_owner "maintain evolution audit" || exit $?

  echo "--- senses preflight: ship-event divergence and health digest ---"
  python3 "$SCRIPTS/senses_deadman.py" --workspace-root "$REPO" || true

  echo "--- owner: FLOW maintain evolution drain ---"
  run_flow_owner "maintain evolution drain" || exit $?

  _RUN_OUTCOME=ok
  echo "=== done: $(date) ==="
} 2>&1 | tee "$LOG"
