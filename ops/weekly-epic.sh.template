#!/bin/bash
# Flow weekly high-altitude producer. Copy to ~/.flow-evolve/weekly-epic.sh,
# replace {{REPO}}, and test-fire before arming its launchd timer.
#
# The command runs as one synchronous owner session. Its native collaboration
# agents own discovery fan-out and waiting; Flow's worker-pool reducers enforce the
# surrounding capacity and read-only guards. Epics remain
# producer-only; the maintainer explicitly expands an accepted epic later.

set -uo pipefail
export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH:-}"

REPO="{{REPO}}"
FLOW_HOST="${FLOW_HOST:-claude}"
FLOW_REFRESH_CMD="${FLOW_REFRESH_CMD:-}"
LOG="$HOME/.flow-evolve/logs/epic-$(date +%Y%m%d-%H%M%S).log"
RECORD="$HOME/.flow-evolve/run-record.jsonl"

record() {
  printf '{"schedule":"weekly","phase":"%s","ts":"%s","outcome":"%s"}\n' \
    "$1" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "${2:-}" >>"$RECORD"
}

run_flow_owner() {
  local command="$1"
  case "$FLOW_HOST" in
    claude)
      claude -p "/flow $command"
      ;;
    codex)
      codex exec "\$flow:flow $command"
      ;;
    *)
      echo "unsupported FLOW_HOST=$FLOW_HOST (expected claude or codex)" >&2
      return 2
      ;;
  esac
}

{
  echo "=== Flow weekly epic: $(date) (host=$FLOW_HOST) ==="
  _RUN_OUTCOME=fail
  trap 'record end "$_RUN_OUTCOME"' EXIT
  record start
  cd "$REPO" || { echo "repo not found: $REPO"; exit 1; }

  SCRIPTS="$REPO/plugins/flow/skills/flow/scripts"
  branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '?')"
  echo "--- clean-boundary preflight before checkout/plugin mutation ---"
  if python3 "$SCRIPTS/maintainer_preflight.py" \
    --run-record "$RECORD" --workspace-root "$REPO" \
    --require-clean-boundary --json; then
    if [ "$branch" = "main" ]; then
      git fetch origin --quiet || true
      if git merge --ff-only origin/main; then
        if [ -n "$FLOW_REFRESH_CMD" ]; then
          echo "--- refreshing configured host installation ---"
          /bin/bash -lc "$FLOW_REFRESH_CMD" || true
        fi
      else
        echo "(ff-only skipped: checkout diverged; proposing as-is)"
      fi
    else
      echo "(repo on '$branch', not main; proposing against current checkout)"
    fi
  else
    echo "(checkout/plugin refresh skipped: dirty checkout or live/corrupt run lease)"
  fi

  echo "--- owner: FLOW maintain evolution epic ---"
  run_flow_owner "maintain evolution epic" || exit $?

  echo "--- filed epics (review, then expand explicitly) ---"
  bd list --type epic --status open 2>&1 || true

  _RUN_OUTCOME=ok
  echo "=== done: $(date) ==="
} 2>&1 | tee "$LOG"
